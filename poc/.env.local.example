# POC 用の環境変数。`.env.local` にコピーして値を埋める（git 管理外）。
# 本プロジェクトルートの .env.local を継承する設計なので、ここでは差分だけ。

# 手段2: rettiwt-api 用
# Chrome 拡張「X Auth Helper」or Firefox 拡張「Rettiwt Auth Helper」で取得
RETTIWT_API_KEY=

# 手段1: Playwright Chrome のログイン補助用
# パスワードをチャットや git に貼らないこと。poc/.env.local にだけ置く。
X_LOGIN_ID=
X_LOGIN_PASSWORD=
# X が追加確認で username を求める場合だけ設定（@なし）
X_LOGIN_USERNAME=

# 手段4: X API pay-per-use 用
# https://developer.x.com/ で Developer アカウント作成後、Bearer Token を取得
X_API_BEARER_TOKEN=

# 手段3: xAI API は親の .env.local の XAI_API_KEY を使う
