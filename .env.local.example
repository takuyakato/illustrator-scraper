# ==========================================
# illustrator-scraper 環境変数テンプレート
# このファイルをコピーして `.env.local` を作成してください
# `.env.local` は git 管理対象外（.gitignore で除外）
# ==========================================

# ---- Supabase ----
# Supabaseダッシュボード → Project Settings → API から取得
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# service_role キー（サーバーサイド専用・絶対にクライアントに渡さない）
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---- Notion ----
# Claude.Bisque インテグレーションのシークレット
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# メインDB（イラストレーター情報）
NOTION_MAIN_DB_ID=e72fd069-f428-4a4a-946e-d8c61f115345
# Berryfeel別DB
NOTION_BERRYFEEL_DB_ID=2cac5063-7a7b-808e-889c-fef08afa0f73
# 同期ログ用Notionページ（失敗通知先、Phase 2で作成予定）
NOTION_SYNC_LOG_PAGE_ID=

# ---- Google Sheets ----
# Phase 2 で設定（マイグレーション時点では未使用）
GOOGLE_SHEET_ID=
# Service Account JSON（1行にまとめてJSON文字列として格納）
GOOGLE_SERVICE_ACCOUNT_JSON=

# ---- スクレイパー（Phase 3）----
# X ログイン補助用。パスワードをチャットや git に貼らないこと。
X_LOGIN_ID=
X_LOGIN_PASSWORD=
# X が追加確認で username を求める場合だけ設定（@なし）
X_LOGIN_USERNAME=
# fetch-followings のシード上書き用（任意、@なし）
X_SEED_USERNAME=
# run-all の処理件数上限（任意）。未設定なら対象シード全員。
SCRAPER_SEED_LIMIT=
# run-all のシード間待機ミリ秒
SCRAPER_SEED_DELAY_MS=30000
# true にすると headless 実行
SCRAPER_HEADLESS=false
# true の時だけ Supabase に insert/update する。未設定・false は dry-run。
SCRAPER_WRITE=false

# ---- ログレベル ----
LOG_LEVEL=info
